# Database — defaults to local SQLite, swap for Postgres when ready
DATABASE_URL=sqlite:///./chatbot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/chatbot

# MCP servers — add one line per server you want the backend to execute tools from.
# Naming: MCP_{SERVER_LABEL}_URL where SERVER_LABEL matches the Chatbox server name
# (dashes become underscores, all uppercase).
# Example for Kite MCP (Zerodha):
# MCP_KITE_MCP_URL=https://mcp.kite.trade/sse
